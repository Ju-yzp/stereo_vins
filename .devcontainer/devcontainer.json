{
    "name": "ROS_Container",
    // 这里的 image 填你正在用的镜像，比如 "ros:noetic"
    "image": "depthai_ros_ready",

    "runArgs": [
        "--net=host",
        "--privileged"
    ],
    "containerEnv": {
        "DISPLAY": "${localEnv:DISPLAY}"
    },
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind"
    ]
}
